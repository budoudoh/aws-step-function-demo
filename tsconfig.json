{
  "compilerOptions": {
    "target":           "ES2022",
    "lib":              ["ES2022"],
    "types":            ["node"],
    "module":           "node16",
    "moduleResolution": "node16",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "outDir":           "dist",
    "rootDir":          ".",
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata":  true
  },
  "include": ["bin", "lib", "lambdas"],
  "exclude": ["node_modules", "dist", "cdk.out"]
}
