{
  "name": "step-demo",
  "version": "1.0.0",
  "description": "S.T.E.P. — Snooze Time Extension Protocol (ATL Cloud Conference demo)",
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc -w",
    "cdk":     "cdk",
    "deploy":  "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "diff":    "cdk diff",
    "synth":   "cdk synth"
  },
  "devDependencies": {
    "@types/aws-lambda":          "^8.10.140",
    "@types/node":                "^20",
    "aws-cdk":                    "^2.180.0",
    "esbuild":                    "^0.20.0",
    "typescript":                 "^5.4.5"
  },
  "dependencies": {
    "@aws-sdk/client-sfn":        "^3.600.0",
    "aws-cdk-lib":                "^2.180.0",
    "constructs":                 "^10.0.0",
    "source-map-support":         "^0.5.21"
  }
}
